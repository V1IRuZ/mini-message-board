<html>

<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>New message</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <div class="page">
    <%- include('header') %>
    <main>
      <%- include('partials/errorMessage.ejs') %>
      <form method="POST" action="/new">
        <div class="input">
          <label for="user">NAME</label>
          <input type="text" name="messageUser" id="user" required minlength="3" maxlength="30">
        </div>
        <div class="input">
          <label for="message">MESSAGE</label>
          <textarea type="text" name="messageText" id="message" rows="10" required minlength="1" maxlength="500"></textarea>
        </div>
        <div class="button">
          <button type="submit">POST</button>
        </div>
    </main>
    </form>
  </div>
</body>

</html>