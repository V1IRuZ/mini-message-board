<html>

<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Homepage</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <div class="page">
    <%- include('header') %>
    <main class="board">
      <ul class="msg-list">
        <% messages.map(message => { %>
        <li class="msg-card">
          <a href="/message/<%= message.id %>">
            <h2><%= message.user %></h2>
            <p><%= message.text %></p>
            <span class="open">OPEN</span>
          </a>
        </li>
        <% }) %>
      </ul>
    </main>
  </div>
</body>

</html>