<html>

<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title  %></title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <div class="page">
    <%- include('header') %>
    <main class="msg-content">
      <div class="message">
        <h2><%= message.username %></h2>
        <p><%= message.message %></p>
        <span><%= message.created_at %></span>
      </div>
    </main>
  </div>
</body>

</html>